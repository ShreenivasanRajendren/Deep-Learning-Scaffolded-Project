print("COMPREHENSIVE HYPERPARAMETER ANALYSIS")

def safe_load_csv(filename, fallback_data=None):
    try:
        df = pd.read_csv(filename)
        if df.empty:
            raise FileNotFoundError(f"{filename} is empty")
        print(f"Loaded {filename}: {len(df)} rows")
        return df
    except:
        print(f"{filename} not found/empty - using fallback data")
        if fallback_data:
            df = pd.DataFrame(fallback_data)
            df.to_csv(filename, index=False)
            return df
        return pd.DataFrame()

