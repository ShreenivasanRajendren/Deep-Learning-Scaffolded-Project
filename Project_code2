overflow-x:auto;line-height:normal;font-family:Menlo,'DejaVu Sans Mono',consolas,'Courier New',monospace\"><span style=\"font-weight: bold\"> Non-trainable params: </span><span style=\"color: #00af00; text-decoration-color: #00af00\">0</span> (0.00 B)\n</pre>\n"},"metadata":{}}],"execution_count":14},{"cell_type":"code","source":"# ── Bahdanau-style Self-Attention Layer ───────────────────────────────────────\nclass BahdanauAttention(layers.Layer):\n   \n    def __init__(self, units=64, **kwargs):\n        super().__init__(**kwargs)\n        self.W1 = layers.Dense(units, use_bias=False)\n        self.W2 = layers.Dense(units, use_bias=False)\n        self.V  = layers.Dense(1)\n\n    def call(self, hidden_seq):   # (B, T, D)\n        # score shape: (B, T, 1)\n        score = self.V(tf.nn.tanh(self.W1(hidden_seq) + self.W2(hidden_seq)))\n        attn_weights = tf.nn.softmax(score, axis=1)   # (B, T, 1)\n        context = tf.reduce_sum(attn_weights * hidden_seq, axis=1)  # (B, D)\n        return context, attn_weights\n\n    def get_config(self):\n        base = super().get_config()\n        base.update({'units': self.W1.units})\n        return base\n\ndef build_sequence_model(model_type: str = 'LSTM',\n                          feature_dim: int = 512,\n                          seq_len:     int = 10,\n                          embed_dim:   int = 128,\n                          hidden_units:int = 128,\n                          num_classes: int = 2,\n                          dropout:     float = 0.3,\n                          use_attention: bool = True,\n                          learning_rate: float = 1e-4) -> Model:\n   \n    inp = Input(shape=(seq_len, feature_dim), name='cnn_features_input')\n\n\n    x = layers.Dense(embed_dim, activation='linear', name='frame_embed')(inp)\n    x = layers.LayerNormalization(name='embed_ln')(x)\n    rnn_kwargs = dict(\n        units=hidden_units,\n        return_sequences=use_attention,  # need all steps for attention\n        dropout=dropout,\n        recurrent_dropout=0.1\n    )\n    if model_type == 'RNN':\n        x = layers.SimpleRNN(**rnn_kwargs, name='rnn_layer')(x)\n    elif model_type == 'LSTM':\n        x = layers.LSTM(**rnn_kwargs, name='lstm_layer')(x)\n    elif model_type == 'GRU':\n        x = layers.GRU(**rnn_kwargs, name='gru_layer')(x)\n    else:\n        raise ValueError(f\"Unknown model_type: {model_type}\")\n\n    if use_attention:\n        x, _ = BahdanauAttention(units=hidden_units // 2, name='attention')(x)\n    x = layers.Dense(64, activation='relu', name='fc')(x)\n    x = layers.Dropout(dropout)(x)\n    out = layers.Dense(num_classes, activation='softmax', name='output')(x)\n\n    model = Model(inp, out, name=f'{model_type}_Attention' if use_attention\n                                 else model_type)\n    model.compile(\n        optimizer=keras.optimizers.Adam(learning_rate=learning_rate),\n        loss='sparse_categorical_crossentropy',\n        metrics=['accuracy']\n    )\n    return model\n\n\n# Quick sanity check\ntest_m = build_sequence_model('LSTM',\n                               feature_dim=CFG['CNN_FEATURE_DIM'],\n                               seq_len=CFG['SEQUENCE_LEN'])\ntest_m.summary()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-25T13:20:54.824789Z","iopub.execute_input":"2026-03-25T13:20:54.825226Z","iopub.status.idle":"2026-03-25T13:20:55.063563Z","shell.execute_reply.started":"2026-03-25T13:20:54.825197Z","shell.execute_reply":"2026-03-25T13:20:55.062990Z"}},"outputs":[{"output_type":"display_data","data":{"text/plain":"\u001b[1mModel: \"LSTM_Attention\"\u001b[0m\n","text/html":"<pre style=\"white-space:pre;overflow-x:auto;line-height:normal;font-family:Menlo,'DejaVu Sans Mono',consolas,'Courier New',monospace\"><span style=\"font-weight: bold\">Model: \"LSTM_Attention\"</span>\n</pre>\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":"┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┳━━━━━━━━━━━━━━━━━━━━━━━━┳━━━━━━━━━━━