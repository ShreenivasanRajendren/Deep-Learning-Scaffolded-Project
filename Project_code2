ise normalisation (mean subtraction)\n    mean = np.array([0.485, 0.456, 0.406], dtype=np.float32)\n    std  = np.array([0.229, 0.224, 0.225], dtype=np.float32)\n    img  = (img - mean) / std\n    return img\n\n\ndef build_sequences(df: pd.DataFrame,\n                    seq_len: int = 10,\n                    img_size: int = 224,\n                    stride: int = 1) -> tuple:\n    sequences, labels_out = [], []\n\n    for lbl, grp in tqdm(df.groupby('label_enc'), desc='Building sequences'):\n        paths = grp['path'].tolist()\n        # Sliding window over sorted paths\n        for start in range(0, len(paths) - seq_len + 1, stride):\n            clip = paths[start : start + seq_len]\n            frames = np.stack([load_and_preprocess_frame(p, img_size) for p in clip])\n            sequences.append(frames)\n            labels_out.append(lbl)\n\n    X = np.stack(sequences).astype(np.float32)   \n    y = np.array(labels_out, dtype=np.int32)\n    print(f\"Sequence dataset shape : X={X.shape}, y={y.shape}\")\n    return X, y\n\n\n# Build the dataset (stride=5 to keep memory manageable on Kaggle)\nX_seq, y_seq = build_sequences(\n    df,\n    seq_len  = CFG['SEQUENCE_LEN'],\n    img_size = CFG['IMG_SIZE'],\n    stride   = 5\n)\n\n# Train / val / test split  (70 / 15 / 15)\nX_train, X_tmp, y_train, y_tmp = train_test_split(\n    X_seq, y_seq, test_size=0.30,\n    random_state=CFG['RANDOM_STATE'], stratify=y_seq\n)\nX_val, X_test, y_val, y_test = train_test_split(\n    X_tmp, y_tmp, test_size=0.50,\n    random_state=CFG['RANDOM_STATE'], stratify=y_tmp\n)\nprint(f\"Train={len(X_train)}, Val={len(X_val)}, Test={len(X_test)}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-25T13:08:51.791231Z","iopub.execute_input":"2026-03-25T13:08:51.791647Z","iopub.status.idle":"2026-03-25T13:09:21.913615Z","shell.execute_reply.started":"2026-03-25T13:08:51.791614Z","shell.execute_reply":"2026-03-25T13:09:21.912990Z"}},"outputs":[{"output_type":"display_data","d