def build_lenet(input_shape=(224, 224, 3), feature_dim=512):
    inp = Input(shape=input_shape, name='lenet_input')
    x = layers.Conv2D(32, (5, 5), activation='relu', padding='same', name='lenet_c1')(inp)
    x = layers.AveragePooling2D((2, 2), name='lenet_p1')(x)
    x = layers.Conv2D(64, (5, 5), activation='relu', padding='same', name='lenet_c2')(x)
    x = layers.AveragePooling2D((2, 2), name='lenet_p2')(x)
    x = layers.Conv2D(128, (3, 3), activation='relu', padding='same', name='lenet_c3')(x)
    x = layers.GlobalAveragePooling2D(name='lenet_gap')(x)
    x = layers.Dense(feature_dim, activation='relu', name='lenet_feat')(x)
    x = layers.Dropout(CFG['DROPOUT'])(x)
    model = Model(inp, x, name='LeNet_FeatureExtractor')
    return model

