def build_finetuned_vgg16(input_shape=(224, 224, 3),
                           unfreeze_from_layer='block5_conv1',
                           num_classes=2):
  
    base = VGG16(weights='imagenet', include_top=False, input_shape=input_shape)

    # Step 1: freeze everything
    for layer in base.layers:
        layer.trainable = False

    # Step 2: unfreeze from the specified layer onward
    unfreeze = False
    for layer in base.layers:
        if layer.name == unfreeze_from_layer:
            unfreeze = True
        layer.trainable = unfreeze

    trainable_names = [l.name for l in base.layers if l.trainable]
    print(f"Unfrozen layers ({len(trainable_names)}): {trainable_names}")

    # Classification head
    x = base.output
    x = layers.GlobalAveragePooling2D()(x)
    x = layers.Dense(256, activation='relu')(x)
    x = layers.Dropout(0.4)(x)
    out = layers.Dense(num_classes, activation='softmax', name='output')(x)

    model = Model(base.input, out, name='VGG16_FineTuned')
    model.compile(
        optimizer=keras.optimizers.Adam(learning_rate=1e-5),  # low LR for fine-tuning
        loss='sparse_categorical_crossentropy',
        metrics=['accuracy']
    )
    return model

