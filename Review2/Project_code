# ── Bahdanau-style Self-Attention Layer ───────────────────────────────────────
class BahdanauAttention(layers.Layer):
   
    def __init__(self, units=64, **kwargs):
        super().__init__(**kwargs)
        self.W1 = layers.Dense(units, use_bias=False)
        self.W2 = layers.Dense(units, use_bias=False)
        self.V  = layers.Dense(1)

    def call(self, hidden_seq):   # (B, T, D)
        # score shape: (B, T, 1)
        score = self.V(tf.nn.tanh(self.W1(hidden_seq) + self.W2(hidden_seq)))
        attn_weights = tf.nn.softmax(score, axis=1)   # (B, T, 1)
        context = tf.reduce_sum(attn_weights * hidden_seq, axis=1)  # (B, D)
        return context, attn_weights

    def get_config(self):
        base = super().get_config()
        base.update({'units': self.W1.units})
        return base

def build_sequence_model(model_type: str = 'LSTM',
                          feature_dim: int = 512,
                          seq_len:     int = 10,
                          embed_dim:   int = 128,
                          hidden_units:int = 128,
                          num_classes: int = 2,
                          dropout:     float = 0.3,
                          use_attention: bool = True,
                          learning_rate: float = 1e-4) -> Model:
   
    inp = Input(shape=(seq_len, feature_dim), name='cnn_features_input')


    x = layers.Dense(embed_dim, activation='linear', name='frame_embed')(inp)
    x = layers.LayerNormalization(name='embed_ln')(x)
    rnn_kwargs = dict(
        units=hidden_units,
        return_sequences=use_attention,  # need all steps for attention
        dropout=dropout,
        recurrent_dropout=0.1
    )
    if model_type == 'RNN':
        x = layers.SimpleRNN(**rnn_kwargs, name='rnn_layer')(x)
    elif model_type == 'LSTM':
        x = layers.LSTM(**rnn_kwargs, name='lstm_layer')(x)
    elif model_type == 'GRU':
        x = layers.GRU(**rnn_kwargs, name='gru_layer')(x)
    else:
        raise ValueError(f"Unknown model_type: {model_type}")

    if use_attention:
        x, _ = BahdanauAttention(units=hidden_units // 2, name='attention')(x)
    x = layers.Dense(64, activation='relu', name='fc')(x)
    x = layers.Dropout(dropout)(x)
    out = layers.Dense(num_classes, activation='softmax', name='output')(x)

    model = Model(inp, out, name=f'{model_type}_Attention' if use_attention
                                 else model_type)
    model.compile(
        optimizer=keras.optimizers.Adam(learning_rate=learning_rate),
        loss='sparse_categorical_crossentropy',
        metrics=['accuracy']
    )
    return model


