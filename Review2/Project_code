def extract_cnn_features(sequences: np.ndarray,
                          extractor: Model,
                          batch_size: int = 8) -> np.ndarray:
    N, T, H, W, C = sequences.shape
    flat = sequences.reshape(N * T, H, W, C)           
    feats = extractor.predict(flat, batch_size=batch_size, verbose=0)
    return feats.reshape(N, T, -1).astype(np.float32)  

