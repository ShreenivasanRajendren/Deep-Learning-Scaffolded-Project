def get_attention_weights(model, sample_sequence: np.ndarray):
   
    try:
        attn_layer = model.get_layer('attention')
    except ValueError:
        print("No attention layer found in this model.")
        return None

    rnn_output_tensor = attn_layer.input
    _, attn_weights   = attn_layer(rnn_output_tensor)
    attn_model = Model(inputs=model.input, outputs=attn_weights)

    seq = np.expand_dims(sample_sequence, axis=0)  # (1, T, D)
    weights = attn_model.predict(seq, verbose=0)   # (1, T, 1)
    return weights[0, :, 0]  # (T,)

