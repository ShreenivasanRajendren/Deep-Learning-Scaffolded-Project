def build_alexnet_extractor(input_shape=(224, 224, 3), feature_dim=512):
    """
    Simplified AlexNet-style feature extractor.
    5 conv blocks + maxpool + GlobalAveragePooling.
    """
    inp = Input(shape=input_shape, name='alexnet_input')
    # Block 1
    x = layers.Conv2D(96, (11, 11), strides=4, activation='relu',
                      padding='same', name='alex_c1')(inp)
    x = layers.MaxPooling2D((3, 3), strides=2, name='alex_p1')(x)
    x = layers.BatchNormalization()(x)
    # Block 2
    x = layers.Conv2D(256, (5, 5), activation='relu',
                      padding='same', name='alex_c2')(x)
    x = layers.MaxPooling2D((3, 3), strides=2, name='alex_p2')(x)
    x = layers.BatchNormalization()(x)
    # Blocks 3-5
    x = layers.Conv2D(384, (3, 3), activation='relu', padding='same', name='alex_c3')(x)
    x = layers.Conv2D(384, (3, 3), activation='relu', padding='same', name='alex_c4')(x)
    x = layers.Conv2D(256, (3, 3), activation='relu', padding='same', name='alex_c5')(x)
    x = layers.MaxPooling2D((3, 3), strides=2, name='alex_p3')(x)
    x = layers.GlobalAveragePooling2D(name='alex_gap')(x)
    x = layers.Dense(feature_dim, activation='relu', name='alex_feat')(x)
    x = layers.Dropout(CFG['DROPOUT'])(x)
    model = Model(inp, x, name='AlexNet_FeatureExtractor')
    return model

