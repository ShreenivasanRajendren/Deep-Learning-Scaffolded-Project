def build_vgg16_extractor(input_shape=(224, 224, 3), feature_dim=512, trainable=False):
   
    base = VGG16(weights='imagenet', include_top=False, input_shape=input_shape)
    base.trainable = trainable   # freeze for pure extraction; unfreeze for fine-tune

    inp = base.input
    x   = base.output
    x   = layers.GlobalAveragePooling2D(name='vgg_gap')(x)
    x   = layers.Dense(feature_dim, activation='relu', name='vgg_feat')(x)
    x   = layers.Dropout(CFG['DROPOUT'])(x)
    model = Model(inp, x, name='VGG16_FeatureExtractor')
    return model

