def add_frame_embedding(seq_input, embed_dim=128, name_prefix='emb'):
    
    x = layers.Dense(embed_dim, activation='linear',
                      name=f'{name_prefix}_projection')(seq_input)
    x = layers.LayerNormalization(name=f'{name_prefix}_layernorm')(x)
    return x

